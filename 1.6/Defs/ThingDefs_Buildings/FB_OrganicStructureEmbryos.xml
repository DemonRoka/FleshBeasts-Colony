<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- База построек: EmbryoStructureBase -->
  <ThingDef ParentName="BuildingNaturalBase" Name="EmbryoStructureBase" Abstract="True">
    <category>Building</category>
    <thingClass>FB.Building_FleshAnimatedStructure</thingClass>
    <altitudeLayer>Building</altitudeLayer>
    <useHitPoints>True</useHitPoints>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
    </statBases>
    <tickerType>Rare</tickerType>
    <selectable>true</selectable>
    <drawerType>RealtimeOnly</drawerType>
    <blockWind>true</blockWind>
    <building>
      <destroyEffecter>FleshmassHeartDestroyed</destroyEffecter>
      <deconstructible>false</deconstructible>
      <isEdifice>false</isEdifice>
      <isInert>true</isInert>
      <isTargetable>true</isTargetable>
      <claimable>false</claimable>
      <canBuildNonEdificesUnder>false</canBuildNonEdificesUnder>
      <artificialForMeditationPurposes>false</artificialForMeditationPurposes>
      <repairable>false</repairable>
      <ai_combatDangerous>true</ai_combatDangerous>
    </building>
    <comps>
      <li Class="FB.CompProperties_MarkSelfForAbsorption" />
    </comps>
  </ThingDef>
  <!-- Постройка: Embryonic Colony Heart (FB_EmbryoColonyHeart) -->
  <ThingDef ParentName="EmbryoStructureBase">
    <defName>FB_EmbryoColonyHeart</defName>
    <label>Embryonic Colony Heart</label>
    <description>An immature heart organ that will grow into a colony heart.</description>
    <size>(3,3)</size>
    <comps>
      <li Class="FB.CompProperties_EmbryoGrowth">
        <totalMaturationTicks>5000</totalMaturationTicks>
        <targetDef>FB_ColonyHeart</targetDef>
      </li>
      <li Class="FB.CompProperties_FleshAnimationManager">
        <animationAmplitude>0.05</animationAmplitude>
        <animationSideAmplitude>0.03</animationSideAmplitude>
        <baseAnimationSpeed>0.5</baseAnimationSpeed>
        <beatDurationTicks>30</beatDurationTicks>
        <animatedParts>
          <li>
            <texturePath>Things/Building/FB_Organic/ColonyHeart/EmbryoColonyHeart</texturePath>
            <positionOffset>(0, 0, 0)</positionOffset>
            <textureScale>1.5</textureScale>
            <animationAmplitude>0.05</animationAmplitude>
            <animationSideAmplitude>0.03</animationSideAmplitude>
            <animationInterval>0</animationInterval>
            <animationOffset>0.0</animationOffset>
            <altitudeLayer>0</altitudeLayer>
            <rotationAngle>0</rotationAngle>
            <beatDelay>0</beatDelay>
          </li>
        </animatedParts>
      </li>
      <li Class="FB.CompProperties_HemogelUpkeep">
        <hemogelPerHour>0.3</hemogelPerHour>
      </li>
    </comps>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <texPath>Things/Building/FB_Organic/ColonyHeart/EmbryoColonyHeart</texPath>
      <drawSize>(0.1,0.1)</drawSize>
    </graphicData>
  </ThingDef>
