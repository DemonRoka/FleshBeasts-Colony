<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Предмет: flesh biomass (FB_FleshBiomass) -->
  <ThingDef ParentName="OrganicProductBase">
    <defName>FB_FleshBiomass</defName>
    <tradeability>None</tradeability>
    <label>flesh biomass</label>
    <description>A dense serving of edible colony biomass. Nutritious and safe, though deeply unsettling to anyone not bound to the flesh colony.</description>
    <possessionCount>10</possessionCount>
    <graphicData>
      <texPath>Things/Item/Resource/FleshBiomass</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <socialPropernessMatters>true</socialPropernessMatters>
    <statBases>
      <MarketValue>10.0</MarketValue>
      <Mass>0.05</Mass>
      <Nutrition>0.5</Nutrition>
      <FoodPoisonChanceFixedHuman>0.00</FoodPoisonChanceFixedHuman>
      <DeteriorationRate>20</DeteriorationRate>
    </statBases>
    <stackLimit>20</stackLimit>
    <ingestible>
      <foodType>Meal</foodType>
      <preferability>MealAwful</preferability>
      <tasteThought>FB_AteFleshBiomass</tasteThought>
      <ingestEffect>EatVegetarian</ingestEffect>
      <ingestSound>Meal_Eat</ingestSound>
      <lowPriorityCaravanFood>true</lowPriorityCaravanFood>
      <babiesCanIngest>true</babiesCanIngest>
    </ingestible>
    <comps>
      <li Class="CompProperties_Rottable">
        <daysToRotStart>2</daysToRotStart>
        <rotDestroys>true</rotDestroys>
      </li>
    </comps>
    <thingCategories>
      <li>FoodMeals</li>
    </thingCategories>
    <allowedArchonexusCount>150</allowedArchonexusCount>
  </ThingDef>

  <!-- Предмет: hemogel ration chunk (FB_HemogelRation) -->
  <ThingDef ParentName="MealBaseIngredientless">
    <defName>FB_HemogelRation</defName>
    <tradeability>None</tradeability>
    <possessionCount>10</possessionCount>
    <graphicData>
      <texPath>Things/Item/Resource/HemogelRation</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <statBases>
      <MarketValue>12</MarketValue>
      <Mass>0.15</Mass>
      <Nutrition>0.5</Nutrition>
      <FoodPoisonChanceFixedHuman>0</FoodPoisonChanceFixedHuman>
      <DeteriorationRate>0.25</DeteriorationRate>
    </statBases>
    <stackLimit>50</stackLimit>
    <ingestible>
      <foodType>Meal</foodType>
      <preferability>MealSimple</preferability>
      <tasteThought>FB_AteFleshBiomass</tasteThought>
      <optimalityOffsetHumanlikes>-5</optimalityOffsetHumanlikes>
      <optimalityOffsetFeedingAnimals>-100</optimalityOffsetFeedingAnimals>
      <ingestEffect>EatVegetarian</ingestEffect>
      <ingestSound>Meal_Eat</ingestSound>
      <babiesCanIngest>true</babiesCanIngest>
    </ingestible>
    <allowedArchonexusCount>100</allowedArchonexusCount>
  </ThingDef>

  <!-- Предмет: organic component (FB_OrganicComponent) -->
  <ThingDef ParentName="ResourceBase">
    <defName>FB_OrganicComponent</defName>
    <tradeability>None</tradeability>
    <label>organic component</label>
    <description>A bundle of prepared living tissue used to craft organic machinery, symbiotic gear, and flesh-grown weapons.</description>
    <possessionCount>2</possessionCount>
    <graphicData>
      <texPath>Things/Item/Resource/OrganicComponent</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Grain_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <stackLimit>50</stackLimit>
    <healthAffectsPrice>false</healthAffectsPrice>
    <statBases>
      <MaxHitPoints>60</MaxHitPoints>
      <MarketValue>40</MarketValue>
      <Mass>0.5</Mass>
      <Flammability>0.8</Flammability>
      <DeteriorationRate>3.0</DeteriorationRate>
    </statBases>
    <intricate>true</intricate>
    <thingCategories>
      <li>Manufactured</li>
    </thingCategories>
    <allowedArchonexusCount>10</allowedArchonexusCount>
    <stuffProps>
      <color>(139,69,19)</color>
    </stuffProps>
  </ThingDef>
  <!-- Предмет: unfinished organic component (UnfinishedOrganicComponent) -->
  <ThingDef ParentName="UnfinishedBase">
    <defName>UnfinishedOrganicComponent</defName>
    <label>unfinished organic component</label>
    <description>An unfinished organic component.</description>
    <statBases>
      <Flammability>0.5</Flammability>
    </statBases>
    <graphicData>
      <texPath>Things/Item/Unfinished/UnfinishedOrganicComponent</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <stuffCategories Inherit="false" />
  </ThingDef>
  <!-- База предметов: BaseWeapon_LivingLink -->
  <ThingDef Name="BaseWeapon_LivingLink" ParentName="BaseWeapon" Abstract="True">
    <techLevel>Ultra</techLevel>
    <tradeNeverStack>true</tradeNeverStack>
    <relicChance>3</relicChance>
    <weaponTags>
      <li>LivingLink</li>
    </weaponTags>
    <tradeTags>
      <li>WeaponMelee</li>
    </tradeTags>
    <weaponClasses>
      <li>Ultratech</li>
    </weaponClasses>
    <comps>
      <li Class="CompProperties_BladelinkWeapon" MayRequire="Ludeon.RimWorld.Royalty">
        <biocodeOnEquip>False</biocodeOnEquip>
      </li>
      <li Class="CompProperties_GeneratedName" MayRequire="Ludeon.RimWorld.Royalty">
        <nameMaker MayRequire="Ludeon.RimWorld.Royalty">NamerWeaponBladelink</nameMaker>
      </li>
    </comps>
    <smeltable>false</smeltable>
    <burnableByRecipe>true</burnableByRecipe>
    <notifyMapRemoved>true</notifyMapRemoved>
    <thingSetMakerTags>
      <li>WeaponLivingLink</li>
    </thingSetMakerTags>
  </ThingDef>
  <!-- Предмет: Flesh Blade (FB_FleshBlade) -->
  <ThingDef ParentName="BaseWeapon_LivingLink">
    <defName>FB_FleshBlade</defName>
    <tradeability>None</tradeability>
    <label>Flesh Blade</label>
    <description>A living weapon born from a flesh-plant that entwines a plasteel blade, creating a symbiotic Flesh Blade. This grotesque yet powerful sword pulses with organic life, its plasteel edge honed by the plant's growth. Embedded with an onboard persona, it bonds with a single wielder, enhancing their combat prowess with synchronized reflexes, speed, and creative strike patterns.</description>
    <statBases>
      <MarketValue>1000</MarketValue>
      <Mass>2.5</Mass>
    </statBases>
    <equippedAngleOffset>-65</equippedAngleOffset>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <texPath>Things/Item/Equipment/WeaponMelee/FleshBlade</texPath>
      <color>(1,1,1)</color>
    </graphicData>
    <soundInteract MayRequire="Ludeon.RimWorld.Royalty">Interact_BladelinkMonoSword</soundInteract>
    <meleeHitSound MayRequire="Ludeon.RimWorld.Royalty">MeleeHit_BladelinkMonoSword</meleeHitSound>
    <smeltable>false</smeltable>
    <weaponClasses>
      <li>Melee</li>
      <li>MeleePiercer</li>
    </weaponClasses>
    <tools>
      <li>
        <label>organic hilt</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>12</power>
        <cooldownTime>1.6</cooldownTime>
      </li>
      <li>
        <label>plasteel edge</label>
        <capacities>
          <li>Stab</li>
        </capacities>
        <power>27</power>
        <cooldownTime>1.6</cooldownTime>
        <armorPenetration>0.9</armorPenetration>
      </li>
      <li>
        <label>living edge</label>
        <capacities>
          <li>Cut</li>
        </capacities>
        <power>27</power>
        <cooldownTime>1.6</cooldownTime>
        <armorPenetration>0.9</armorPenetration>
      </li>
    </tools>
  </ThingDef>
  <!-- Предмет: Crimson Fang (FB_CrimsonFang) -->
  <ThingDef ParentName="BaseWeapon_LivingLink">
    <defName>FB_CrimsonFang</defName>
    <tradeability>None</tradeability>
    <label>Crimson Fang</label>
    <description>A living weapon grown from a flesh-tendril wrapped around a crescent plasteel blade. Its grotesque form pulses with organic life, while crimson veins channel energy into its razor edge. The fleshy core embedded in the handle beats like a heart, strengthening the wielder’s reflexes and lending hunger to each strike.</description>
    <statBases>
      <MarketValue>1000</MarketValue>
      <Mass>2.7</Mass>
    </statBases>
    <equippedAngleOffset>-70</equippedAngleOffset>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <texPath>Things/Item/Equipment/WeaponMelee/CrimsonFang</texPath>
      <color>(1,1,1)</color>
    </graphicData>
    <soundInteract MayRequire="Ludeon.RimWorld.Royalty">Interact_BladelinkMonoSword</soundInteract>
    <meleeHitSound MayRequire="Ludeon.RimWorld.Royalty">MeleeHit_BladelinkMonoSword</meleeHitSound>
    <smeltable>false</smeltable>
    <weaponClasses>
      <li>Melee</li>
      <li>MeleePiercer</li>
    </weaponClasses>
    <tools>
      <li>
        <label>fleshy core</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>13</power>
        <cooldownTime>1.6</cooldownTime>
      </li>
      <li>
        <label>crimson edge</label>
        <capacities>
          <li>Stab</li>
        </capacities>
        <power>28</power>
        <cooldownTime>1.6</cooldownTime>
        <armorPenetration>0.95</armorPenetration>
      </li>
      <li>
        <label>living crescent</label>
        <capacities>
          <li>Cut</li>
        </capacities>
        <power>28</power>
        <cooldownTime>1.6</cooldownTime>
        <armorPenetration>0.95</armorPenetration>
      </li>
    </tools>
  </ThingDef>
