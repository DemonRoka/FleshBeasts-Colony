<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Источник работы: carry to auto research (CarryToFBAutoResearch) -->
  <WorkGiverDef>
    <defName>CarryToFBAutoResearch</defName>
    <label>carry to auto research</label>
    <giverClass>FB.WorkGiver_CarryToAutoResearch</giverClass>
    <workType>Hauling</workType>
    <verb>insert</verb>
    <gerund>inserting</gerund>
    <priorityInType>90</priorityInType>
    <requiredCapacities>
      <li>Manipulation</li>
      <li>Moving</li>
    </requiredCapacities>
    <canBeDoneByMechs>false</canBeDoneByMechs>
  </WorkGiverDef>

  <!-- Источник работы: carry selected donor to genophage cocoon (FB_CarryToGenophageCocoon) -->
