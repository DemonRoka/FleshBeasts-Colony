<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Состояние: forced flesh conversion brain burn (FB_ForcedFleshConversionBrainBurn) -->
  <HediffDef>
    <defName>FB_ForcedFleshConversionBrainBurn</defName>
    <label>flesh-burned brain</label>
    <description>The colony’s psychic pattern has burned through this pawn’s nervous system, leaving thought and motion unstable while the flesh slowly repairs the damage.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.9, 0.35, 0.35)</defaultLabelColor>
    <stages>
      <li>
        <painOffset>0.15</painOffset>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.25</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.2</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.15</offset>
          </li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>900000</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

  <!-- Состояние: forced flesh conversion stupor (FB_ForcedFleshConversionStupor) -->
  <HediffDef>
    <defName>FB_ForcedFleshConversionStupor</defName>
    <label>flesh-induced stupor</label>
    <description>The pawn’s mind has gone silent while the colony overwrites resistance and binds the body into its shared rhythm.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.9, 0.35, 0.35)</defaultLabelColor>
    <stages>
      <li>
        <painFactor>0</painFactor>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <setMax>0.1</setMax>
          </li>
          <li>
            <capacity>Moving</capacity>
            <setMax>0</setMax>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <setMax>0</setMax>
          </li>
          <li>
            <capacity>Talking</capacity>
            <setMax>0</setMax>
          </li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="FB.HediffCompProperties_RandomDisappearTicks">
        <minTicks>120000</minTicks>
        <maxTicks>360000</maxTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

  <!-- Состояние: failed forced flesh conversion shock (FB_ForcedFleshConversionDeathShock) -->
  <HediffDef>
    <defName>FB_ForcedFleshConversionDeathShock</defName>
    <label>failed flesh acceptance shock</label>
    <description>This body died while being forced into the colony’s pattern. If restored, it will remain weakened while the new bond stabilizes.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.9, 0.35, 0.35)</defaultLabelColor>
    <stages>
      <li>
        <painOffset>0.1</painOffset>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.12</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.2</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.15</offset>
          </li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>1800000</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>
</Defs>
