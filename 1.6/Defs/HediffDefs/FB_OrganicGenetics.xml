<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <HediffDef>
    <defName>FB_GeneticReweavingFatigue</defName>
    <label>genetic reweaving fatigue</label>
    <description>The pawn's genome is bruised by a failed organic reweaving procedure, leaving the body slow to stabilize.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <initialSeverity>0.2</initialSeverity>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-0.5</severityPerDay>
      </li>
    </comps>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.05</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.5</minSeverity>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.1</offset>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>
</Defs>
