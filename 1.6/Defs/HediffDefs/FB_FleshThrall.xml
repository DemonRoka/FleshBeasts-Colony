          <li>Things/Pawn/Fleshbeast/Trispike/Attachments/Top/Trispike_TopLimb_east</li>
          <li>Things/Pawn/Fleshbeast/Trispike/Attachments/Top/Trispike_TopLimb_north</li>
          <li>Things/Pawn/Fleshbeast/Trispike/Attachments/Top/Trispike_TopLimb_south</li>
        </texPaths>
      </li>
      <li Class="FB.PawnRenderNodeProperties_TexDecals">
        <debugLabel>Flesh thrall invasive limbs (non-humanlike)</debugLabel>
        <nodeClass>PawnRenderNode_AnimalPart</nodeClass>
        <workerClass>FB.PawnRenderNodeWorker_TexDecals</workerClass>
        <overlayLayer>Body</overlayLayer>
        <baseLayer>99</baseLayer>
        <pawnType>NonHumanlikeOnly</pawnType>
        <texSeed>31613</texSeed>
        <decalCount>4</decalCount>
        <maxTotalTries>650</maxTotalTries>
        <minDecalDistance>0.18</minDecalDistance>
        <baseScale>0.30</baseScale>
        <scaleJitter>0.75~1.25</scaleJitter>
        <baseAspect>1</baseAspect>
        <aspectJitter>1~1</aspectJitter>
        <randomAngle>0~360</randomAngle>
        <radialAngleChance>0.8</radialAngleChance>
        <radialAngleJitter>-18~18</radialAngleJitter>
        <attachU>0.5</attachU>
        <attachV>0.5</attachV>
        <clipToBodyAlpha>true</clipToBodyAlpha>
        <bodyAlphaThreshold>0.25</bodyAlphaThreshold>
        <decalAlphaThreshold>0.05</decalAlphaThreshold>
        <minCoverage>0.48</minCoverage>
        <samplesPerSide>7</samplesPerSide>
        <wobbleAmount>5</wobbleAmount>
        <wobbleSpeed>1.7</wobbleSpeed>
        <decalAltitudeBase>0.0015</decalAltitudeBase>
        <decalAltitudePerBaseLayer>0.0000025</decalAltitudePerBaseLayer>
        <decalAltitudeStep>0.00004</decalAltitudeStep>
        <texPaths>
          <li>Things/Pawn/Fleshbeast/Bulbfreak/Tentacles/BulbfreakTentacleA</li>
          <li>Things/Pawn/Fleshbeast/Bulbfreak/Tentacles/BulbfreakTentacleB</li>
          <li>Things/Pawn/Fleshbeast/Bulbfreak/Tentacles/BulbfreakTentacleC</li>
          <li>Things/Pawn/Fleshbeast/Fingerspike/Attachments/Fingerspike_TopLimb</li>
          <li>Things/Pawn/Fleshbeast/Toughspike/Attachments/Toughspike_Spike</li>
          <li>Things/Pawn/Fleshbeast/Trispike/Attachments/Side/Trispike_SideLimb_east</li>
          <li>Things/Pawn/Fleshbeast/Trispike/Attachments/Side/Trispike_SideLimb_north</li>
          <li>Things/Pawn/Fleshbeast/Trispike/Attachments/Side/Trispike_SideLimb_south</li>
          <li>Things/Pawn/Fleshbeast/Trispike/Attachments/Top/Trispike_TopLimb_east</li>
          <li>Things/Pawn/Fleshbeast/Trispike/Attachments/Top/Trispike_TopLimb_north</li>
          <li>Things/Pawn/Fleshbeast/Trispike/Attachments/Top/Trispike_TopLimb_south</li>
        </texPaths>
      </li>
