      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Plasteel</li>
          </thingDefs>
        </filter>
        <count>20</count>
      </li>
    </ingredients>
    <products>
      <BudFlesh_FleshBladeSeed>1</BudFlesh_FleshBladeSeed>
    </products>
  </RecipeDef>

