<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Рецепт: Make Personality Parasite Egg (MakePersonalityParasiteEgg) -->
  <RecipeDef ParentName="PlantFleshRecipe_Base">
    <defName>MakePersonalityParasiteEgg</defName>
    <label>Make Personality Parasite Egg</label>
    <description>Craft a personality parasite egg from organic components, bioferrite, and uranium. The egg hatches into a parasite that can carry a stored mind.</description>
    <jobString>Creating Personality Parasite Egg</jobString>
    <workAmount>8000</workAmount>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>FB_OrganicComponent</li>
          </thingDefs>
        </filter>
        <count>15</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Bioferrite</li>
          </thingDefs>
        </filter>
        <count>60</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Uranium</li>
          </thingDefs>
        </filter>
        <count>20</count>
      </li>
    </ingredients>
    <products>
      <FB_EggPersonalityParasite>1</FB_EggPersonalityParasite>
    </products>
    <skillRequirements>
      <Crafting>10</Crafting>
    </skillRequirements>
    <researchPrerequisite>ParasiteEggConversion</researchPrerequisite>
  </RecipeDef>

  <!-- Рецепт: make organic component (Make_OrganicComponent) -->
  <RecipeDef>
    <defName>Make_OrganicComponent</defName>
    <label>make organic component</label>
    <description>Craft an organic component from raw meat and leather for living structures, symbiotic equipment, and flesh-grown weapons.</description>
    <jobString>Assembling organic component.</jobString>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <effectWorking>Cook</effectWorking>
    <soundWorking>Recipe_Machining</soundWorking>
    <workAmount>2500</workAmount>
    <unfinishedThingDef>UnfinishedOrganicComponent</unfinishedThingDef>
    <ingredients>
      <li>
        <filter>
          <categories>
            <li>MeatRaw</li>
          </categories>
        </filter>
        <count>30</count>
      </li>
      <li>
        <filter>
          <categories>
            <li>Leathers</li>
          </categories>
        </filter>
        <count>50</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <categories>
        <li>Leathers</li>
        <li>MeatRaw</li>
      </categories>
    </fixedIngredientFilter>
    <products>
      <FB_OrganicComponent>1</FB_OrganicComponent>
    </products>
    <skillRequirements>
      <Crafting>10</Crafting>
    </skillRequirements>
    <workSkill>Crafting</workSkill>
    <displayPriority>10</displayPriority>
    <recipeUsers>
      <li>FB_SporeCradle</li>
    </recipeUsers>
  </RecipeDef>

  <!-- База рецептов: PlantFleshRecipe_Base -->
  <RecipeDef Name="PlantFleshRecipe_Base" Abstract="True">
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <workSkillLearnFactor>0.5</workSkillLearnFactor>
    <recipeUsers>
      <li>FB_SporeCradle</li>
    </recipeUsers>
    <effectWorking>Cook</effectWorking>
    <soundWorking>Recipe_CookMeal</soundWorking>
    <skillRequirements>
      <Crafting>5</Crafting>
    </skillRequirements>
    <researchPrerequisite>FleshSeedCreation</researchPrerequisite>
  </RecipeDef>

