<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Раса: scrapmeld (FB_Scrapmeld) -->
  <ThingDef ParentName="BaseFleshbeast">
    <defName>FB_Scrapmeld</defName>
    <label>scrapmeld</label>
    <description>A grotesque combination of flesh and twisted steel, Scrapmeld roams the battlefield, absorbing the remains of mechanoids and studying the design of their weapons. Once he has figured out the next shell, he temporarily reproduces its armament and turns it against his enemies. But it cannot keep such a system operational for long: the metal crumbles, the mechanisms fall apart, and only mutilated synthetic debris and living flesh remain in its body.</description>
    <statBases>
      <MoveSpeed>1.2</MoveSpeed>
      <MinimumContainmentStrength>20</MinimumContainmentStrength>
      <ToxicResistance>0.5</ToxicResistance>
    </statBases>
    <race>
      <thinkTreeMain>FB_ScrapmeldMain</thinkTreeMain>
      <thinkTreeConstant>FleshbeastConstant</thinkTreeConstant>
      <body>FB_ScrapmeldBody</body>
      <baseBodySize>3.2</baseBodySize>
      <baseHealthScale>8</baseHealthScale>
      <lifeExpectancy>10</lifeExpectancy>
      <renderTree>Misc</renderTree>
      <deathAction Class="DeathActionProperties_Vanish">
        <workerClass>DeathActionWorker_Vanish</workerClass>
        <filth>Filth_TwistedFlesh</filth>
        <filthCountRange>1~3</filthCountRange>
        <meatExplosionSize>Small</meatExplosionSize>
      </deathAction>
      <lifeStageAges>
        <li>
          <def>EntityFullyFormed</def>
          <soundWounded>Pawn_Fleshbeast_Fingerspike_Wounded</soundWounded>
          <soundDeath>Pawn_Fleshbeast_Fingerspike_Death</soundDeath>
          <soundCall>Pawn_Fleshbeast_Fingerspike_Call</soundCall>
        </li>
      </lifeStageAges>
      <canBePredatorPrey>false</canBePredatorPrey>
    </race>
    <inspectorTabs>
      <li>FB.ITab_ScrapmeldInventory</li>
    </inspectorTabs>
    <comps>
      <li Class="FB.CompProperties_FleshbeastDraftable" />
      <li Class="FB.CompProperties_ScrapmeldOrders">
        <iconPath>UI/Commands/ScrapmeldAbsorbMechanoid</iconPath>
      </li>
      <li Class="FB.CompProperties_ScrapmeldWeaponCopy">
        <maxStoredMass>250</maxStoredMass>
        <studyTicksPerBodySize>60000</studyTicksPerBodySize>
        <minimumStudyTicks>6000</minimumStudyTicks>
        <activeUseTicksForBodySizeOne>300000</activeUseTicksForBodySizeOne>
        <minimumActiveUseTicks>10000</minimumActiveUseTicks>
        <slagChunksPerBodySize>2</slagChunksPerBodySize>
        <minimumSlagChunks>1</minimumSlagChunks>
      </li>
      <li Class="CompProperties_Studiable">
        <frequencyTicks>120000</frequencyTicks>
        <knowledgeCategory>Basic</knowledgeCategory>
        <minMonolithLevelForStudy>1</minMonolithLevelForStudy>
        <anomalyKnowledge>1</anomalyKnowledge>
        <requiresHoldingPlatform>true</requiresHoldingPlatform>
      </li>
    </comps>
    <tools>
      <li>
        <label>head</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>4</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>1.0</chanceFactor>
        <soundMeleeHit>Pawn_Fleshbeast_Attack_Blunt</soundMeleeHit>
      </li>
    </tools>
  </ThingDef>
  <!-- Раса: scrapmeld seed (FB_ScrapmeldNestling) -->
  <ThingDef ParentName="BaseFleshbeast">
    <defName>FB_ScrapmeldNestling</defName>
    <label>scrapmeld seed</label>
    <description>An unfinished larva of a mature Scrapmeld. It prowls near the colony, automatically absorbing mechanoid corpses that lie within the home area. Once enough synthetic mass is consumed, it reshapes itself into a full Scrapmeld.</description>
    <statBases>
      <MoveSpeed>2.2</MoveSpeed>
      <MinimumContainmentStrength>12</MinimumContainmentStrength>
      <ToxicResistance>0.35</ToxicResistance>
    </statBases>
    <race>
      <thinkTreeMain>FB_ScrapmeldNestlingMain</thinkTreeMain>
      <thinkTreeConstant>FB_ScrapmeldConstant</thinkTreeConstant>
      <body>FB_ScrapmeldNestlingBody</body>
      <baseBodySize>1.1</baseBodySize>
      <baseHealthScale>0.28</baseHealthScale>
      <lifeExpectancy>8</lifeExpectancy>
      <renderTree>Misc</renderTree>
      <deathAction Class="DeathActionProperties_Vanish">
        <workerClass>DeathActionWorker_Vanish</workerClass>
        <filth>Filth_TwistedFlesh</filth>
        <filthCountRange>1~2</filthCountRange>
        <meatExplosionSize>Small</meatExplosionSize>
      </deathAction>
      <lifeStageAges>
        <li>
          <def>EntityFullyFormed</def>
          <soundWounded>Pawn_Fleshbeast_Fingerspike_Wounded</soundWounded>
          <soundDeath>Pawn_Fleshbeast_Fingerspike_Death</soundDeath>
          <soundCall>Pawn_Fleshbeast_Fingerspike_Call</soundCall>
        </li>
      </lifeStageAges>
      <canBePredatorPrey>false</canBePredatorPrey>
    </race>
    <comps>
      <li Class="FB.CompProperties_ScrapmeldNestlingNest">
        <requiredMechanoidMass>200</requiredMechanoidMass>
        <consumeDurationTicks>180</consumeDurationTicks>
        <inspectLabel>FB_ScrapmeldNestling_AbsorbedMechMass</inspectLabel>
      </li>
    </comps>
    <tools>
      <li>
        <label>gnashing mass</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>3</power>
        <cooldownTime>2.3</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>1.0</chanceFactor>
        <soundMeleeHit>Pawn_Fleshbeast_Attack_Blunt</soundMeleeHit>
      </li>
    </tools>
  </ThingDef>
</Defs>
