<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="BaseFleshbeast">
    <defName>FB_Chromophage</defName>
    <label>chromophage</label>
    <description>A fused fleshbeast shaped around a sealed flesh-colony host. Its swollen sensory organs are built to strip genetic traces from dead humanlike bodies and carry them back to a living genome archive.</description>
    <statBases>
      <MoveSpeed>2.6</MoveSpeed>
      <MinimumContainmentStrength>70</MinimumContainmentStrength>
      <ToxicResistance>0.5</ToxicResistance>
      <MarketValue>1500</MarketValue>
    </statBases>
    <uiIconPath>Things/Pawn/FB_Chromophage/Chromophage_MenuIcon</uiIconPath>
    <race>
      <body>Bulbfreak</body>
      <baseBodySize>3.6</baseBodySize>
      <baseHealthScale>0.32</baseHealthScale>
      <lifeExpectancy>15</lifeExpectancy>
      <soundMoving>Pawn_Fleshbeast_Bulbfreak_Moving</soundMoving>
      <deathAction Class="DeathActionProperties_Divide">
        <divideBloodFilthCountRange>3~4</divideBloodFilthCountRange>
        <dividePawnCount>1</dividePawnCount>
        <dividePawnKindOptions>
          <li>Fingerspike</li>
          <li>Trispike</li>
        </dividePawnKindOptions>
      </deathAction>
      <renderTree>Animal</renderTree>
      <lifeStageAges>
        <li>
          <def>EntityFullyFormed</def>
          <soundWounded>Pawn_Fleshbeast_Bulbfreak_Wounded</soundWounded>
          <soundDeath>Pawn_Fleshbeast_Bulbfreak_Death</soundDeath>
          <soundCall>Pawn_Fleshbeast_Bulbfreak_Call</soundCall>
        </li>
      </lifeStageAges>
      <canBePredatorPrey>false</canBePredatorPrey>
    </race>
    <inspectorTabs>
      <li>FB.ITab_OrganicGeneArchiveContents</li>
    </inspectorTabs>
    <comps>
      <li Class="FB.CompProperties_FleshbeastDraftable" />
      <li Class="FB.CompProperties_BulbfreakHostStorage" />
      <li Class="FB.CompProperties_ChromophageGenepackContainer">
        <maxCapacity>8</maxCapacity>
      </li>
      <li Class="CompProperties_Power">
        <compClass>FB.CompSilentGeneArchivePower</compClass>
        <basePowerConsumption>0</basePowerConsumption>
        <showPowerNeededIfOff>false</showPowerNeededIfOff>
      </li>
      <li Class="FB.CompProperties_ChromophageGeneHarvester">
        <capacity>8</capacity>
        <extractWorkTicks>420</extractWorkTicks>
        <unloadWorkTicks>240</unloadWorkTicks>
      </li>
    </comps>
    <tools>
      <li>
        <label>tendril</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>4</power>
        <cooldownTime>2.6</cooldownTime>
        <alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
        <linkedBodyPartsGroup>FirstTentacle</linkedBodyPartsGroup>
        <soundMeleeHit>Pawn_Fleshbeast_Attack_Blunt</soundMeleeHit>
      </li>
      <li>
        <label>head</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>3</power>
        <cooldownTime>2.4</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <soundMeleeHit>Pawn_Fleshbeast_Attack_Blunt</soundMeleeHit>
      </li>
    </tools>
  </ThingDef>
</Defs>
