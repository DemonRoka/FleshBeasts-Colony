<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Раса: thrallbloom (FB_Thrallbloom) -->
  <ThingDef ParentName="BaseFleshbeast">
    <defName>FB_Thrallbloom</defName>
    <label>thrallbloom</label>
    <description>A vast floating knot of neural flesh and trailing tendrils, thrallbloom is bred for advanced battlefield domination. Deep inside its swollen crown, living budlink organs cast out mental tethers that seize hostile human minds and overwrite them with obedient impulse. It can sustain several such bonds at once, but every active link gnaws at its own cognition. When the thrallbloom is stunned or rendered unconscious, those tethered minds can snap free in a violent wave of synaptic backlash.</description>
    <tradeability>None</tradeability>
    <uiIconPath>Things/Pawn/FB_Thrallbloom/FB_Thrallbloom_south</uiIconPath>
    <statBases>
      <MoveSpeed>2.42</MoveSpeed>
      <ComfyTemperatureMin>-40</ComfyTemperatureMin>
      <ComfyTemperatureMax>60</ComfyTemperatureMax>
      <Flammability>1.1</Flammability>
      <MinimumContainmentStrength>95</MinimumContainmentStrength>
      <ToxicResistance>0.65</ToxicResistance>
      <MarketValue>420</MarketValue>
      <MeatAmount>40</MeatAmount>
      <ArmorRating_Blunt>0.42</ArmorRating_Blunt>
      <ArmorRating_Sharp>0.34</ArmorRating_Sharp>
      <ArmorRating_Heat>0.20</ArmorRating_Heat>
      <EnergyShieldRechargeRate>0.12</EnergyShieldRechargeRate>
      <EnergyShieldEnergyMax>0.5</EnergyShieldEnergyMax>
    </statBases>
    <race>
      <body>FB_ThrallbloomBody</body>
      <intelligence>ToolUser</intelligence>
      <specificMeatDef>Meat_Twisted</specificMeatDef>
      <disableIgniteVerb>true</disableIgniteVerb>
      <canOpenFactionlessDoors>true</canOpenFactionlessDoors>
      <bloodDef>Filth_Blood</bloodDef>
      <bloodSmearDef>Filth_BloodSmear</bloodSmearDef>
      <soundMeleeDodge>Pawn_MeleeDodge</soundMeleeDodge>
      <trainability>None</trainability>
      <baseBodySize>2.3</baseBodySize>
      <baseHungerRate>0.24</baseHungerRate>
      <baseHealthScale>3.4</baseHealthScale>
      <lifeExpectancy>20</lifeExpectancy>
      <renderTree>Animal</renderTree>
      <thinkTreeMain>FB_ThrallbloomMain</thinkTreeMain>
      <thinkTreeConstant>FleshbeastConstant</thinkTreeConstant>
      <needsRest>false</needsRest>
      <hasGenders>false</hasGenders>
      <foodType>None</foodType>
      <canBePredatorPrey>false</canBePredatorPrey>
      <fleshType>Fleshbeast</fleshType>
      <isImmuneToInfections>true</isImmuneToInfections>
      <bleedRateFactor>0.5</bleedRateFactor>
      <hediffGiverSets>
        <li>Fleshbeast</li>
      </hediffGiverSets>
      <soundMoving>Pawn_Fleshbeast_Dreadmeld_Moving</soundMoving>
      <deathAction Class="DeathActionProperties_Vanish">
        <workerClass>DeathActionWorker_Vanish</workerClass>
        <filth>Filth_TwistedFlesh</filth>
        <filthCountRange>3~5</filthCountRange>
        <meatExplosionSize>Small</meatExplosionSize>
      </deathAction>
      <lifeStageAges>
        <li>
          <def>EntityFullyFormed</def>
          <soundWounded>Pawn_Fleshbeast_Dreadmeld_Wounded</soundWounded>
          <soundDeath>Pawn_Fleshbeast_Dreadmeld_Death</soundDeath>
          <soundCall>Pawn_Fleshbeast_Dreadmeld_Call</soundCall>
        </li>
      </lifeStageAges>
    </race>
    <comps>
      <li Class="FB.CompProperties_FleshbeastDraftable" />
      <li Class="CompProperties_Shield">
        <startingTicksToReset>2500</startingTicksToReset>
        <minDrawSize>1.45</minDrawSize>
        <maxDrawSize>2.25</maxDrawSize>
        <energyLossPerDamage>0.01</energyLossPerDamage>
        <energyOnReset>0.2</energyOnReset>
        <blocksRangedWeapons>false</blocksRangedWeapons>
      </li>
      <li Class="FB.CompProperties_ThrallbloomController">
        <linkHediffDef>FB_ThrallbloomNeuralLink</linkHediffDef>
        <maxLinkedTargets>3</maxLinkedTargets>
        <manualCastRadius>20</manualCastRadius>
        <autoAcquireRadius>12</autoAcquireRadius>
        <autoSearchIntervalTicks>90</autoSearchIntervalTicks>
        <maxLinkDistance>28</maxLinkDistance>
        <thrallDefenseRadius>12</thrallDefenseRadius>
        <desiredHoldDistance>5.5</desiredHoldDistance>
        <holdDistanceTolerance>1.25</holdDistanceTolerance>
        <thrallIdleDistance>4.8</thrallIdleDistance>
        <thrallIdleTolerance>1.25</thrallIdleTolerance>
        <thrallLeashDistance>11.5</thrallLeashDistance>
        <thrallThreatRadius>14</thrallThreatRadius>
        <thrallHoldJobDurationTicks>150</thrallHoldJobDurationTicks>
        <supportEnemyDistance>9</supportEnemyDistance>
        <linkSlotCooldownTicks>7500</linkSlotCooldownTicks>
        <autoEnabledByDefault>false</autoEnabledByDefault>
        <gizmoLabel>FB_Thrallbloom_TetherLabel</gizmoLabel>
        <gizmoDesc>FB_Thrallbloom_TetherDesc</gizmoDesc>
        <iconPath>UI/Commands/NeuralLinks</iconPath>
        <rejectMessage>FB_Thrallbloom_RejectTarget</rejectMessage>
        <maxLinksMessage>FB_Thrallbloom_MaxLinks</maxLinksMessage>
        <noReadySlotsMessage>FB_Thrallbloom_NoReadySlots</noReadySlotsMessage>
        <ropeTexturePath>Things/Building/Cable</ropeTexturePath>
        <ropeColor>(0.75,0.44,0.44,0.82)</ropeColor>
        <ropeWidth>0.18</ropeWidth>
        <ropeAltitude>Filth</ropeAltitude>
        <ropeYOffset>0.0015</ropeYOffset>
        <ropeBendStrength>0.22</ropeBendStrength>
        <ropeBendMax>0.35</ropeBendMax>
        <ropeSegments>5</ropeSegments>
      </li>
    </comps>
    <tools>
      <li>
        <label>tether tendrils</label>
        <capacities>
          <li>Cut</li>
        </capacities>
        <power>16</power>
        <cooldownTime>2.4</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>1.0</chanceFactor>
        <soundMeleeHit>Pawn_Dreadmeld_Attack_Spike</soundMeleeHit>
      </li>
      <li>
        <label>thrashing underside</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>11</power>
        <cooldownTime>2.0</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.35</chanceFactor>
        <soundMeleeHit>Pawn_Fleshbeast_Attack_Blunt</soundMeleeHit>
      </li>
    </tools>
  </ThingDef>
</Defs>
