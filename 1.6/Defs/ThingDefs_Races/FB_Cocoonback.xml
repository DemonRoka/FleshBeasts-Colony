<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Раса: cocoonback (FB_Cocoonback) -->
  <ThingDef ParentName="BaseFleshbeast">
    <defName>FB_Cocoonback</defName>
    <label>cocoonback</label>
    <description>A living containment beast with its own hemogel reservoir. It seals humanlike captives inside a back cocoon, feeding and sedating them until release.</description>
    <tradeability>None</tradeability>
    <uiIconPath>Things/Pawn/FB_Cocoonback/Cocoonback_south</uiIconPath>
    <statBases>
      <MoveSpeed>1.3</MoveSpeed>
      <ComfyTemperatureMin>-35</ComfyTemperatureMin>
      <ComfyTemperatureMax>60</ComfyTemperatureMax>
      <Flammability>1.1</Flammability>
      <MinimumContainmentStrength>65</MinimumContainmentStrength>
      <ToxicResistance>0.65</ToxicResistance>
      <MarketValue>360</MarketValue>
      <MeatAmount>32</MeatAmount>
      <ArmorRating_Blunt>0.24</ArmorRating_Blunt>
      <ArmorRating_Sharp>0.18</ArmorRating_Sharp>
    </statBases>
    <race>
      <body>FB_CocoonbackBody</body>
      <intelligence>ToolUser</intelligence>
      <specificMeatDef>Meat_Twisted</specificMeatDef>
      <disableIgniteVerb>true</disableIgniteVerb>
      <canOpenFactionlessDoors>false</canOpenFactionlessDoors>
      <bloodDef>Filth_Blood</bloodDef>
      <bloodSmearDef>Filth_BloodSmear</bloodSmearDef>
      <soundMeleeDodge>Pawn_MeleeDodge</soundMeleeDodge>
      <trainability>None</trainability>
      <baseBodySize>2.35</baseBodySize>
      <baseHungerRate>0.18</baseHungerRate>
      <baseHealthScale>2.25</baseHealthScale>
      <lifeExpectancy>24</lifeExpectancy>
      <renderTree>Animal</renderTree>
      <thinkTreeMain>FB_CocoonbackMain</thinkTreeMain>
      <thinkTreeConstant>FB_CocoonbackConstant</thinkTreeConstant>
      <needsRest>false</needsRest>
      <hasGenders>false</hasGenders>
      <foodType>None</foodType>
      <canBePredatorPrey>false</canBePredatorPrey>
      <fleshType>Fleshbeast</fleshType>
      <isImmuneToInfections>true</isImmuneToInfections>
      <bleedRateFactor>0.55</bleedRateFactor>
      <lifeStageAges>
        <li>
          <def>EntityFullyFormed</def>
          <soundWounded>Pawn_Fleshbeast_Fingerspike_Wounded</soundWounded>
          <soundDeath>Pawn_Fleshbeast_Fingerspike_Death</soundDeath>
          <soundCall>Pawn_Fleshbeast_Fingerspike_Call</soundCall>
        </li>
      </lifeStageAges>
      <deathAction Class="DeathActionProperties_Vanish">
        <workerClass>DeathActionWorker_Vanish</workerClass>
        <filth>Filth_TwistedFlesh</filth>
        <filthCountRange>3~6</filthCountRange>
        <meatExplosionSize>Small</meatExplosionSize>
      </deathAction>
    </race>
    <tools>
      <li>
        <label>crushing maw</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>5</power>
        <cooldownTime>3.2</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <soundMeleeHit>Pawn_Fleshbeast_Attack_Blunt</soundMeleeHit>
      </li>
    </tools>
    <comps>
      <li Class="FB.CompProperties_HemogelStorage">
        <initialHemogelCapacity>820</initialHemogelCapacity>
        <maxHemogelCapacity>820</maxHemogelCapacity>
        <showHemogelInInspector>true</showHemogelInInspector>
      </li>
      <li Class="FB.CompProperties_CocoonbackContainment">
        <maxCapacity>10</maxCapacity>
        <baseHemogelPerCapture>40</baseHemogelPerCapture>
        <hemogelPerBleedingSeverity>18</hemogelPerBleedingSeverity>
        <hemogelPerBleedingWound>6</hemogelPerBleedingWound>
        <restoreIntervalTicks>2500</restoreIntervalTicks>
        <upkeepIntervalTicks>2500</upkeepIntervalTicks>
        <foodRestorePerInterval>0.08</foodRestorePerInterval>
        <restRestorePerInterval>0.1</restRestorePerInterval>
        <hemogelDrainPerPawnPerDay>14</hemogelDrainPerPawnPerDay>
        <lowHemogelThresholdPercent>0.1</lowHemogelThresholdPercent>
        <refillPerTick>4.2</refillPerTick>
        <heartSearchRadius>90</heartSearchRadius>
        <releaseAnestheticSeverity>1</releaseAnestheticSeverity>
        <captureGizmoLabel>FB_Cocoonback_Cocoon</captureGizmoLabel>
        <captureGizmoDesc>FB_Cocoonback_DefaultCaptureDesc</captureGizmoDesc>
        <releaseGizmoLabel>FB_Cocoonback_ReleaseCaptive</releaseGizmoLabel>
        <releaseGizmoDesc>FB_Cocoonback_DefaultReleaseDesc</releaseGizmoDesc>
        <captureIconPath>UI/Commands/CocoonbackCapture</captureIconPath>
        <releaseIconPath>UI/Commands/CocoonbackRelease</releaseIconPath>
        <notEnoughHemogelMessage>FB_Cocoonback_NotEnoughHemogel</notEnoughHemogelMessage>
        <noCaptivesMessage>FB_Cocoonback_NoCaptives</noCaptivesMessage>
        <capacityFullMessage>FB_Cocoonback_CapacityFull</capacityFullMessage>
        <ropeTexturePath>Things/Building/Cable</ropeTexturePath>
        <southDisplayZone>
          <pointA>
            <x>-0.35</x>
            <z>-0.50</z>
          </pointA>
          <pointB>
            <x>0.35</x>
            <z>0.05</z>
          </pointB>
        </southDisplayZone>
        <eastDisplayZone>
          <pointA>
            <x>-0.27</x>
            <z>-0.4</z>
          </pointA>
          <pointB>
            <x>0.05</x>
            <z>0.4</z>
          </pointB>
        </eastDisplayZone>
        <northDisplayZone>
          <pointA>
            <x>-0.28</x>
            <z>0.42</z>
          </pointA>
          <pointB>
            <x>0.28</x>
            <z>-0.05</z>
          </pointB>
        </northDisplayZone>
      </li>
    </comps>
  </ThingDef>
</Defs>
