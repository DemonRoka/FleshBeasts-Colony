<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Раса: ferrimaw (FB_Ferrimaw) -->
  <ThingDef ParentName="BasePawn">
    <defName>FB_Ferrimaw</defName>
    <label>ferrimaw</label>
    <description>A squat refinery fleshbeast with a grinding maw and a distended ferric gut. It prowls the colony's interior, swallowing loose steel whenever its hunger dips, then slowly extrudes warm nodules of bioferrite as the metal is worked through its living furnace. Ferrimaws are poor fighters but useful metabolic engines for any flesh colony that has more steel than it can meaningfully spend.</description>
    <tradeability>None</tradeability>
    <uiIconPath>Things/Pawn/FB_Ferrimaw/FB_Ferrimaw_south</uiIconPath>
    <statBases>
      <MoveSpeed>1.08</MoveSpeed>
      <WorkSpeedGlobal>0.7</WorkSpeedGlobal>
      <MeleeHitChance>0.72</MeleeHitChance>
      <ComfyTemperatureMin>-30</ComfyTemperatureMin>
      <ComfyTemperatureMax>60</ComfyTemperatureMax>
      <Flammability>1.0</Flammability>
      <MeatAmount>9</MeatAmount>
      <Mass>18</Mass>
      <MarketValue>165</MarketValue>
      <ToxicResistance>0.75</ToxicResistance>
    </statBases>
    <race>
      <body>FB_FerrimawBody</body>
      <baseBodySize>1.7</baseBodySize>
      <baseHungerRate>0.15</baseHungerRate>
      <baseHealthScale>0.95</baseHealthScale>
      <lifeExpectancy>15</lifeExpectancy>
      <renderTree>Animal</renderTree>
      <intelligence>ToolUser</intelligence>
      <trainability>None</trainability>
      <thinkTreeMain>FB_FerrimawMain</thinkTreeMain>
      <thinkTreeConstant>FleshbeastConstant</thinkTreeConstant>
      <specificMeatDef>Meat_Twisted</specificMeatDef>
      <canOpenFactionlessDoors>false</canOpenFactionlessDoors>
      <needsRest>false</needsRest>
      <hasGenders>false</hasGenders>
      <foodType>OmnivoreRoughAnimal</foodType>
      <canBePredatorPrey>false</canBePredatorPrey>
      <bloodDef>Filth_Blood</bloodDef>
      <bloodSmearDef>Filth_BloodSmear</bloodSmearDef>
      <soundMeleeDodge>Pawn_MeleeDodge</soundMeleeDodge>
      <fleshType>Fleshbeast</fleshType>
      <isImmuneToInfections>true</isImmuneToInfections>
      <bleedRateFactor>0.46</bleedRateFactor>
      <corpseHiddenWhileUndiscovered>true</corpseHiddenWhileUndiscovered>
      <lifeStageAges>
        <li>
          <def>EntityFullyFormed</def>
          <soundWounded>Pawn_Fleshbeast_Toughspike_Wounded</soundWounded>
          <soundDeath>Pawn_Fleshbeast_Toughspike_Death</soundDeath>
          <soundCall>Pawn_Fleshbeast_Toughspike_Call</soundCall>
        </li>
      </lifeStageAges>
    </race>
    <comps>
      <li Class="FB.CompProperties_FerrimawMetabolism">
        <steelPerBioferrite>8</steelPerBioferrite>
        <foodPercentPerBioferrite>0.2</foodPercentPerBioferrite>
        <seekSteelBelowFoodPercent>0.78</seekSteelBelowFoodPercent>
        <urgentSeekSteelBelowFoodPercent>0.35</urgentSeekSteelBelowFoodPercent>
        <consumeBaseDurationTicks>90</consumeBaseDurationTicks>
        <consumeTicksPerSteel>12</consumeTicksPerSteel>
        <failedSearchCooldownTicks>2000</failedSearchCooldownTicks>
        <maxItemsPerConsumption>75</maxItemsPerConsumption>
        <autoConsumeIconPath>UI/Commands/Consume</autoConsumeIconPath>
        <metabolismPausedHediff>FB_FerrimawMetalMetabolismPaused</metabolismPausedHediff>
        <metalSources>
          <li>
            <thingDef>Steel</thingDef>
            <steelEquivalent>1</steelEquivalent>
          </li>
          <li>
            <thingDef>ChunkSlagSteel</thingDef>
            <steelEquivalent>15</steelEquivalent>
          </li>
          <li>
            <thingDef>ChunkMechanoidSlag</thingDef>
            <steelEquivalent>15</steelEquivalent>
          </li>
        </metalSources>
        <wanderRadius>12</wanderRadius>
      </li>
    </comps>
    <tools>
      <li>
        <label>crusher maw</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>6</power>
        <cooldownTime>2.4</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.45</chanceFactor>
        <soundMeleeHit>Pawn_Fleshbeast_Attack_Blunt</soundMeleeHit>
      </li>
      <li>
        <label>left rasping limb</label>
        <capacities>
          <li>Cut</li>
        </capacities>
        <power>5</power>
        <cooldownTime>2.5</cooldownTime>
        <linkedBodyPartsGroup>FirstTentacle</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.35</chanceFactor>
        <soundMeleeHit>Pawn_Dreadmeld_Attack_Spike</soundMeleeHit>
      </li>
      <li>
        <label>right rasping limb</label>
        <capacities>
          <li>Cut</li>
        </capacities>
        <power>5</power>
        <cooldownTime>2.5</cooldownTime>
        <linkedBodyPartsGroup>SecondTentacle</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.35</chanceFactor>
        <soundMeleeHit>Pawn_Dreadmeld_Attack_Spike</soundMeleeHit>
      </li>
    </tools>
  </ThingDef>
</Defs>
