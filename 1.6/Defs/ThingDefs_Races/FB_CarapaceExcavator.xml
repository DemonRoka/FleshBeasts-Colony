<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Раса: carapace excavator (FB_CarapaceExcavator) -->
  <ThingDef ParentName="BasePawn">
    <defName>FB_CarapaceExcavator</defName>
    <label>carapace excavator</label>
    <description>A heavy excavation fleshbeast bred for tunnel labor. It breaks player-designated rock inside its allowed area, then returns to a colony heart to regrow worn plates through the hemogel network.</description>
    <tradeability>None</tradeability>
    <uiIconPath>Things/Pawn/FB_CarapaceExcavator/FB_CarapaceExcavator_south</uiIconPath>
    <statBases>
      <MoveSpeed>1.69</MoveSpeed>
      <ComfyTemperatureMin>-35</ComfyTemperatureMin>
      <ComfyTemperatureMax>65</ComfyTemperatureMax>
      <Flammability>0.9</Flammability>
      <MeatAmount>0</MeatAmount>
      <MarketValue>190</MarketValue>
      <ToxicResistance>0.8</ToxicResistance>
      <WorkSpeedGlobal>1.5</WorkSpeedGlobal>
      <MiningSpeed>3</MiningSpeed>
      <ArmorRating_Blunt>0.22</ArmorRating_Blunt>
      <ArmorRating_Sharp>0.28</ArmorRating_Sharp>
    </statBases>
    <race>
      <body>FB_CarapaceExcavatorBody</body>
      <baseBodySize>1.65</baseBodySize>
      <baseHungerRate>0.22</baseHungerRate>
      <baseHealthScale>1.3</baseHealthScale>
      <lifeExpectancy>16</lifeExpectancy>
      <renderTree>FB_CarapaceExcavatorRender</renderTree>
      <intelligence>ToolUser</intelligence>
      <trainability>None</trainability>
      <thinkTreeMain>FB_CarapaceExcavatorMain</thinkTreeMain>
      <thinkTreeConstant>FleshbeastConstant</thinkTreeConstant>
      <needsRest>false</needsRest>
      <hasGenders>false</hasGenders>
      <foodType>None</foodType>
      <canBePredatorPrey>false</canBePredatorPrey>
      <bloodDef>Filth_Blood</bloodDef>
      <bloodSmearDef>Filth_BloodSmear</bloodSmearDef>
      <fleshType>Fleshbeast</fleshType>
      <isImmuneToInfections>true</isImmuneToInfections>
      <bleedRateFactor>0.45</bleedRateFactor>

      <lifeStageAges>
        <li>
          <def>EntityFullyFormed</def>
          <soundWounded>Pawn_Fleshbeast_Toughspike_Wounded</soundWounded>
          <soundDeath>Pawn_Fleshbeast_Toughspike_Death</soundDeath>
          <soundCall>Pawn_Fleshbeast_Toughspike_Call</soundCall>
        </li>
      </lifeStageAges>
    </race>
    <comps>
      <li Class="FB.CompProperties_CarapaceExcavatorDigTuning">
        <blocksMinedUntilFullyWorn>36</blocksMinedUntilFullyWorn>
					<plateRegrowthPerDay>1.0</plateRegrowthPerDay>
        <minSharpnessToMine>0</minSharpnessToMine>
        <regrowthHemogelPerHour>0.1</regrowthHemogelPerHour>
      </li>
    </comps>
    <tools>
      <li>
        <label>left shovel-claw</label>
        <capacities>
          <li>Cut</li>
        </capacities>
        <power>11</power>
        <cooldownTime>2.4</cooldownTime>
        <linkedBodyPartsGroup>FirstTentacle</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.32</chanceFactor>
        <soundMeleeHit>Pawn_Fleshbeast_Attack_Blunt</soundMeleeHit>
      </li>
      <li>
        <label>right shovel-claw</label>
        <capacities>
          <li>Cut</li>
        </capacities>
        <power>11</power>
        <cooldownTime>2.4</cooldownTime>
        <linkedBodyPartsGroup>SecondTentacle</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.32</chanceFactor>
        <soundMeleeHit>Pawn_Fleshbeast_Attack_Blunt</soundMeleeHit>
      </li>
      <li>
        <label>left digging tusk</label>
        <capacities>
          <li>Stab</li>
        </capacities>
        <power>8</power>
        <cooldownTime>2.6</cooldownTime>
        <linkedBodyPartsGroup>LeftSpike</linkedBodyPartsGroup>
        <chanceFactor>0.18</chanceFactor>
        <soundMeleeHit>Pawn_Fleshbeast_Attack_Blunt</soundMeleeHit>
      </li>
      <li>
        <label>right digging tusk</label>
        <capacities>
          <li>Stab</li>
        </capacities>
        <power>8</power>
        <cooldownTime>2.6</cooldownTime>
        <linkedBodyPartsGroup>RightSpike</linkedBodyPartsGroup>
        <chanceFactor>0.18</chanceFactor>
        <soundMeleeHit>Pawn_Fleshbeast_Attack_Blunt</soundMeleeHit>
      </li>
    </tools>
  </ThingDef>
</Defs>
