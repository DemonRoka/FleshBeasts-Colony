<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Раса: rotlarva (FB_Rotlarva) -->
  <ThingDef ParentName="BaseInsect">
    <defName>FB_Rotlarva</defName>
    <label>rotlarva</label>
    <description>A large, sluggish flesh creature born from the decay of a dead colony-organism. Rotlarvae burrow through decomposing tunnels, feeding on rotting tissue and absorbing leftover hemogel. Normally passive, they become dangerously aggressive when disturbed, lunging at intruders with surprising speed. Their pale, sagging bodies are covered with necrotic patches.</description>
    <statBases>
      <MoveSpeed>2.5</MoveSpeed>
      <ComfyTemperatureMin>-20</ComfyTemperatureMin>
      <MarketValue>150</MarketValue>
      <LeatherAmount>0</LeatherAmount>
      <ArmorRating_Blunt>0.15</ArmorRating_Blunt>
      <ArmorRating_Sharp>0.10</ArmorRating_Sharp>
    </statBases>
    <uiIconScale>1.2</uiIconScale>
    <tools>
      <li>
        <label>flesh maw</label>
        <capacities>
          <li>Bite</li>
        </capacities>
        <power>4</power>
        <cooldownTime>2.5</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
      </li>
      <li>
        <label>body slam</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>2</power>
        <cooldownTime>3</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <chanceFactor>0.2</chanceFactor>
      </li>
    </tools>
    <race>
      <body>FB_FleshLarvaBody</body>
      <thinkTreeMain>FB_RotlarvaMain</thinkTreeMain>
      <thinkTreeConstant>FB_RotlarvaConstant</thinkTreeConstant>
      <baseHungerRate>0.3</baseHungerRate>
      <baseBodySize>1.0</baseBodySize>
      <baseHealthScale>1.5</baseHealthScale>
      <manhunterOnDamageChance>0</manhunterOnDamageChance>
      <specificMeatDef>Meat_Twisted</specificMeatDef>
      <lifeExpectancy>4</lifeExpectancy>
      <trainability>None</trainability>
      <lifeStageAges>
        <li>
          <def>AnimalAdult</def>
          <minAge>0</minAge>
          <soundWounded>Pawn_Spelopede_Pain</soundWounded>
          <soundDeath>Pawn_Spelopede_Death</soundDeath>
          <soundCall>Pawn_Spelopede_Call</soundCall>
          <soundAngry>Pawn_Spelopede_Angry</soundAngry>
        </li>
      </lifeStageAges>
      <soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
      <headPosPerRotation>
        <li>(0.0, 0, 0.14)</li>
        <li>(0.07, 0, 0.08)</li>
        <li>(0.0, 0, -0.12)</li>
        <li>(-0.07, 0, 0.08)</li>
      </headPosPerRotation>
      <deathAction Class="DeathActionProperties_Vanish">
        <workerClass>DeathActionWorker_Vanish</workerClass>
        <filth>Filth_TwistedFlesh</filth>
        <filthCountRange>1~3</filthCountRange>
        <meatExplosionSize>Small</meatExplosionSize>
      </deathAction>
      <canBePredatorPrey>false</canBePredatorPrey>
    </race>
    <comps>
      <li Class="FB.CompProperties_RotlarvaConsumeCooldown">
        <cooldownTicksRange>10000~20000</cooldownTicksRange>
      </li>
    </comps>
