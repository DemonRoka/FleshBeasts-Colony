<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Раса: personality parasite (FB_PersonalityParasite) -->
  <ThingDef ParentName="BasePawn">
    <defName>FB_PersonalityParasite</defName>
    <label>personality parasite</label>
    <description>A newborn parasite has no mind until worn by a colonist. After the host dies, it can be guided into a corpse to restore the stored mind.</description>
    <statBases>
      <MoveSpeed>4</MoveSpeed>
      <ToxicResistance>0.5</ToxicResistance>
      <ComfyTemperatureMin>-40</ComfyTemperatureMin>
      <ComfyTemperatureMax>60</ComfyTemperatureMax>
      <Flammability>1.25</Flammability>
      <MeatAmount>70</MeatAmount>
    </statBases>
    <tools>
      <li>
        <label>tentacle</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>6</power>
        <cooldownTime>1.8</cooldownTime>
        <linkedBodyPartsGroup>FB_CoreTentacles</linkedBodyPartsGroup>
        <alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
        <soundMeleeHit>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHit>
        <soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
      </li>
      <li>
        <label>tentacle</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>6</power>
        <cooldownTime>1.8</cooldownTime>
        <linkedBodyPartsGroup>FB_CoreTentacles</linkedBodyPartsGroup>
        <alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
        <soundMeleeHit>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHit>
        <soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
      </li>
      <li>
        <label>tentacle</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>6</power>
        <cooldownTime>1.8</cooldownTime>
        <linkedBodyPartsGroup>FB_CoreTentacles</linkedBodyPartsGroup>
        <alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
        <soundMeleeHit>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHit>
        <soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
      </li>
    </tools>
    <race>
      <thinkTreeMain>Fleshbeast</thinkTreeMain>
      <thinkTreeConstant>FleshbeastConstant</thinkTreeConstant>
      <body>FB_ParasiteBody</body>
      <foodType>None</foodType>
      <canBePredatorPrey>false</canBePredatorPrey>
      <baseBodySize>0.2</baseBodySize>
      <baseHealthScale>0.5</baseHealthScale>
      <lifeExpectancy>10</lifeExpectancy>
      <deathAction Class="DeathActionProperties_Vanish">
        <workerClass>DeathActionWorker_Vanish</workerClass>
        <filth>Filth_TwistedFlesh</filth>
        <filthCountRange>1~3</filthCountRange>
        <meatExplosionSize>Small</meatExplosionSize>
      </deathAction>
      <lifeStageAges>
        <li>
          <def>EntityFullyFormed</def>
          <soundWounded>Pawn_Fleshbeast_Fingerspike_Wounded</soundWounded>
          <soundDeath>Pawn_Fleshbeast_Fingerspike_Death</soundDeath>
          <soundCall>Pawn_Fleshbeast_Fingerspike_Call</soundCall>
        </li>
      </lifeStageAges>
      <intelligence>ToolUser</intelligence>
      <specificMeatDef>Meat_Twisted</specificMeatDef>
      <canOpenFactionlessDoors>false</canOpenFactionlessDoors>
      <needsRest>false</needsRest>
      <hasGenders>false</hasGenders>
      <bloodDef>Filth_Blood</bloodDef>
      <bloodSmearDef>Filth_BloodSmear</bloodSmearDef>
      <soundMeleeDodge>Pawn_MeleeDodge</soundMeleeDodge>
      <trainability>None</trainability>
      <fleshType>Fleshbeast</fleshType>
      <isImmuneToInfections>true</isImmuneToInfections>
      <bleedRateFactor>0.5</bleedRateFactor>
      <hediffGiverSets />
      <corpseHiddenWhileUndiscovered>true</corpseHiddenWhileUndiscovered>
    </race>
    <tradeability>None</tradeability>
    <comps>
      <li Class="FB.CompProperties_PawnMemory" />
      <li Class="CompProperties_Usable">
        <compClass>FB.CompUsableParasite</compClass>
        <useJob>FB_UsePawn</useJob>
        <useLabel>Install {0_label}</useLabel>
      </li>
      <li Class="FB.CompProperties_UseEffectInstallParasite">
        <hediffDef>FB_PersonalityParasite</hediffDef>
        <bodyPart>Brain</bodyPart>
      </li>
      <li Class="FB.CompProperties_FleshbeastDraftable" />
      <li Class="FB.CompProperties_PersonalityParasiteController" />
    </comps>
