      <Cleanliness>-3</Cleanliness>
      <Flammability>0.32</Flammability>
      <CleaningTimeFactor>1.5</CleaningTimeFactor>
    </statBases>
    <affordances>
      <li>Light</li>
      <li>Diggable</li>
    </affordances>
    <fertility>0.1</fertility>
    <heatPerTick>0.001</heatPerTick>
    <canBePolluted>False</canBePolluted>
    <tags>
      <li>FB_FleshColonyTerrain</li>
    </tags>
  </TerrainDef>
