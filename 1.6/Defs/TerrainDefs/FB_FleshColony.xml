<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Покрытие: flesh veins (FleshVeins) -->
  <TerrainDef ParentName="FloorBase">
    <defName>FleshVeins</defName>
    <label>flesh veins</label>
    <description>A slick layer of exposed flesh veins spread across the ground. It is unpleasant underfoot, but supports colony tissue and organic growth.</description>
    <texturePath>Terrain/Surfaces/FleshVeins</texturePath>
    <edgeType>FadeRough</edgeType>
    <renderPrecedence>340</renderPrecedence>
    <pathCost>2</pathCost>
    <designationCategory />
    <statBases>
      <Beauty>-10</Beauty>
      <BeautyOutdoors>-5</BeautyOutdoors>
      <Cleanliness>-3</Cleanliness>
      <Flammability>0.32</Flammability>
      <CleaningTimeFactor>1.5</CleaningTimeFactor>
    </statBases>
    <affordances>
      <li>Light</li>
      <li>Diggable</li>
    </affordances>
    <fertility>0.1</fertility>
    <heatPerTick>0.0005</heatPerTick>
    <canBePolluted>False</canBePolluted>
    <tags>
      <li>FB_FleshColonyTerrain</li>
    </tags>
  </TerrainDef>
