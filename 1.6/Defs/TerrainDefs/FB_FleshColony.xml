  <!-- Покрытие: gastric acid (FB_GastricAcid) -->
  <TerrainDef ParentName="WaterChestDeepBase">
    <defName>FB_GastricAcid</defName>
    <label>gastric acid</label>
    <description>Caustic digestive fluid secreted by a flesh colony organ. Anything living that stands in it is burned, and organic matter left inside is broken down into hemogel.</description>
    <texturePath>Terrain/Surfaces/GastricAcid</texturePath>
    <pollutedTexturePath>Terrain/Surfaces/GastricAcid</pollutedTexturePath>
    <waterDepthShader>Map/WaterDepth</waterDepthShader>
    <renderPrecedence>393</renderPrecedence>
    <pathCost>150</pathCost>
    <extraDeteriorationFactor>0.1</extraDeteriorationFactor>
    <extraNonDraftedPerceivedPathCost>400</extraNonDraftedPerceivedPathCost>
    <extraDraftedPerceivedPathCost>400</extraDraftedPerceivedPathCost>
    <avoidWander>true</avoidWander>
    <dangerous>true</dangerous>
    <burnDamage>3</burnDamage>
    <burnIntervalTicks>120</burnIntervalTicks>
    <canFreeze>false</canFreeze>
    <temporary>true</temporary>
    <tempTerrain>
      <replaceableByBridge>true</replaceableByBridge>
    </tempTerrain>
    <floodTerrain>FB_GastricAcid</floodTerrain>
    <color>(0.62, 0.90, 0.22)</color>
    <filthAcceptanceMask>
      <li>None</li>
    </filthAcceptanceMask>
    <tags>
      <li>Water</li>
      <li>FB_FleshColonyTerrain</li>
    </tags>
    <passability>Standable</passability>
    <waterBodyType>Other</waterBodyType>
    <affordances>
      <li>Bridgeable</li>
      <li>Walkable</li>
    </affordances>
  </TerrainDef>
</Defs>
