    <defName>FB_FleshFatProtuberances</defName>
    <label>fat flesh protuberances</label>
    <description>Swollen fleshy protrusions packed with soft nutrient tissue. They grow larger than ordinary protrusions and can be harvested for more organic matter.</description>
    <statBases>
      <MaxHitPoints>85</MaxHitPoints>
      <Flammability>1.3</Flammability>
