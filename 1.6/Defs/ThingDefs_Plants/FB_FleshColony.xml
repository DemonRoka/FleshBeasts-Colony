<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Растение: flesh protuberances (FB_FleshProtuberances) -->
  <ThingDef ParentName="PlantBase">
    <defName>FB_FleshProtuberances</defName>
    <label>flesh protuberances</label>
    <description>Small fleshy protrusions that grow from living colony tissue. They can be harvested as a modest source of organic nutrition.</description>
    <statBases>
      <MaxHitPoints>85</MaxHitPoints>
      <Flammability>1.3</Flammability>
      <Nutrition>0.50</Nutrition>
    </statBases>
    <graphicData>
      <texPath>Things/Plant/FleshProtuberance</texPath>
      <graphicClass>Graphic_Random</graphicClass>
    </graphicData>
    <hideAtSnowOrSandDepth>0.5</hideAtSnowOrSandDepth>
    <ingestible />
    <plant>
      <pollution>Any</pollution>
      <fertilityMin>0</fertilityMin>
      <fertilitySensitivity>0</fertilitySensitivity>
      <growDays>2.5</growDays>
      <harvestWork>40</harvestWork>
      <maxMeshCount>9</maxMeshCount>
      <visualSizeRange>0.75~1.05</visualSizeRange>
      <topWindExposure>0.1</topWindExposure>
      <wildOrder>0</wildOrder>
      <maxGrowthTemperature>75</maxGrowthTemperature>
      <growMinGlow>0</growMinGlow>
      <growOptimalGlow>0</growOptimalGlow>
      <cavePlant>true</cavePlant>
      <wildClusterRadius>5</wildClusterRadius>
      <wildClusterWeight>28</wildClusterWeight>
      <wildEqualLocalDistribution>false</wildEqualLocalDistribution>
      <purpose>Misc</purpose>
      <dieFromToxicFallout>false</dieFromToxicFallout>
      <neverBlightable>true</neverBlightable>
      <wildTerrainTags>
        <li>FB_FleshColonyTerrain</li>
      </wildTerrainTags>
    </plant>
  </ThingDef>
  <!-- Растение: fat flesh protuberances (FB_FleshFatProtuberances) -->
