  <!-- Растение: Bud Flesh Blade (BudFlesh_FleshBlade) -->
  <ThingDef ParentName="BudFlesh_WeaponPlantBase">
    <defName>BudFlesh_FleshBlade</defName>
    <label>Bud Flesh Blade</label>
    <description>A flesh-plant grown from a blade seed. Once mature, it can be harvested into a symbiotic Flesh Blade.</description>
    <graphicData>
      <texPath>Things/Plant/BudFlesh_FleshBlade</texPath>
      <graphicClass>Graphic_Random</graphicClass>
    </graphicData>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
    </statBases>
    <descriptionHyperlinks>
      <ThingDef>BudFlesh_FleshBladeSeed</ThingDef>
    </descriptionHyperlinks>
    <selectable>true</selectable>
    <neverMultiSelect>false</neverMultiSelect>
    <pathCost>14</pathCost>
    <preventSkyfallersLandingOn>true</preventSkyfallersLandingOn>
    <plant>
      <immatureGraphicPath>Things/Plant/BudFlesh_FleshBlade_Immature</immatureGraphicPath>
      <fertilitySensitivity>0</fertilitySensitivity>
      <fertilityMin>0.1</fertilityMin>
      <growDays>8</growDays>
      <harvestYield>1</harvestYield>
      <harvestTag>Standard</harvestTag>
      <harvestAfterGrowth>0</harvestAfterGrowth>
      <harvestedThingDef>FB_FleshBlade</harvestedThingDef>
      <harvestFailable>false</harvestFailable>
      <harvestYieldAffectedByDifficulty>false</harvestYieldAffectedByDifficulty>
      <visualSizeRange>1.7~2.3</visualSizeRange>
      <topWindExposure>0.05</topWindExposure>
      <wildClusterWeight>0</wildClusterWeight>
      <purpose>Misc</purpose>
      <allowAutoCut>false</allowAutoCut>
      <dieFromToxicFallout>false</dieFromToxicFallout>
      <warnIfMarkedForCut>true</warnIfMarkedForCut>
      <growMinGlow>0</growMinGlow>
      <growOptimalGlow>0</growOptimalGlow>
      <harvestMinGrowth>0.98</harvestMinGrowth>
      <neverBlightable>true</neverBlightable>
    </plant>
  </ThingDef>
