<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Дерево мышления: bastion spine segment (FB_BastionSpineSegmentMain) -->
  <ThinkTreeDef>
    <defName>FB_BastionSpineSegmentMain</defName>
    <thinkRoot Class="ThinkNode_Priority">
      <subNodes>
        <li Class="ThinkNode_Subtree">
          <treeDef>Despawned</treeDef>
        </li>
        <li Class="ThinkNode_Subtree">
          <treeDef>Downed</treeDef>
        </li>
        <li Class="ThinkNode_Subtree">
          <treeDef>BurningResponse</treeDef>
        </li>
        <li Class="ThinkNode_Subtree">
          <treeDef>MentalStateCritical</treeDef>
        </li>
        <li Class="ThinkNodeConditional_EscapingHoldingPlatform">
          <subNodes>
            <li Class="JobGiver_EscapingHoldingPlatform" />
          </subNodes>
        </li>
        <li Class="ThinkNode_QueuedJob" />
        <li Class="ThinkNode_Subtree">
          <treeDef>MentalStateNonCritical</treeDef>
        </li>
        <li Class="ThinkNode_Subtree">
          <treeDef>RopedPawn</treeDef>
        </li>
        <li Class="ThinkNode_ConditionalForcedGoto">
          <subNodes>
            <li Class="ThinkNode_Tagger">
              <tagToGive>Misc</tagToGive>
              <subNodes>
                <li Class="JobGiver_ForcedGoto" />
              </subNodes>
            </li>
          </subNodes>
        </li>
        <li Class="FB.JobGiver_StaticAbilityFight">
          <targetAcquireRadius>18.5</targetAcquireRadius>
          <targetKeepRadius>20.5</targetKeepRadius>
          <ability>SpineLaunch_Gorehulk</ability>
          <needLOSToAcquireNonPawnTargets>true</needLOSToAcquireNonPawnTargets>
        </li>
        <li Class="JobGiver_AIAbilityFight">
          <targetAcquireRadius>65</targetAcquireRadius>
          <targetKeepRadius>72</targetKeepRadius>
          <skipIfCantTargetNow>false</skipIfCantTargetNow>
          <ability>SpineLaunch_Gorehulk</ability>
          <allowTurrets>true</allowTurrets>
          <needLOSToAcquireNonPawnTargets>true</needLOSToAcquireNonPawnTargets>
        </li>
        <li Class="JobGiver_FleeForDistance">
          <enemyDistToFleeRange>1.9~5.9</enemyDistToFleeRange>
          <fleeDistRange>8~13</fleeDistRange>
        </li>
        <li Class="ThinkNode_Subtree">
          <treeDef>LordDuty</treeDef>
        </li>
        <li Class="ThinkNode_Tagger">
          <tagToGive>Idle</tagToGive>
          <subNodes>
            <li Class="JobGiver_WanderHerd">
              <maxDanger>Deadly</maxDanger>
              <ticksBetweenWandersRange>120~240</ticksBetweenWandersRange>
            </li>
          </subNodes>
        </li>
        <li Class="JobGiver_IdleError" />
      </subNodes>
    </thinkRoot>
  </ThinkTreeDef>

  <!-- Дерево мышления: bastion spine segment constant (FB_BastionSpineSegmentConstant) -->
  <ThinkTreeDef>
    <defName>FB_BastionSpineSegmentConstant</defName>
    <thinkRoot Class="ThinkNode_Priority">
      <subNodes>
        <li Class="ThinkNode_Subtree">
          <treeDef>Despawned</treeDef>
        </li>
        <li Class="ThinkNode_ConditionalCanDoLordJobNow">
          <subNodes>
            <li Class="ThinkNode_Subtree">
              <treeDef>LordDutyConstant</treeDef>
            </li>
          </subNodes>
        </li>
      </subNodes>
    </thinkRoot>
  </ThinkTreeDef>
</Defs>