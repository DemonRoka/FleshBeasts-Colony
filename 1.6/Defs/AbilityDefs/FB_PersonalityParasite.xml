<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <AbilityDef ParentName="AbilityTouchBase">
    <defName>FB_PersonalityParasiteTransferConsciousness</defName>
    <label>transfer consciousness</label>
    <description>Move to a valid humanlike corpse to transfer the stored personality into it, or to a colony brain to store it in memory.</description>
    <iconPath>UI/Commands/PersonalityParasiteTransferConsciousness</iconPath>
    <targetRequired>true</targetRequired>
    <hostile>false</hostile>
    <showPsycastEffects>false</showPsycastEffects>
    <displayGizmoWhileUndrafted>true</displayGizmoWhileUndrafted>
    <disableGizmoWhileUndrafted>false</disableGizmoWhileUndrafted>
    <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
    <jobDef>CastAbilityOnThingMelee</jobDef>
    <verbProperties>
      <verbClass>Verb_CastAbilityTouch</verbClass>
      <warmupTime>0.4</warmupTime>
      <drawAimPie>false</drawAimPie>
      <range>-1</range>
      <targetParams>
        <canTargetPawns>false</canTargetPawns>
        <canTargetBuildings>true</canTargetBuildings>
        <canTargetMechs>false</canTargetMechs>
        <canTargetItems>false</canTargetItems>
        <canTargetCorpses>true</canTargetCorpses>
        <onlyTargetCorpses>false</onlyTargetCorpses>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="FB.CompProperties_AbilityPersonalityParasiteTransferConsciousness" />
    </comps>
  </AbilityDef>
</Defs>
